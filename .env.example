# ─────────────────────────────────────────────
#  WANDR — Auth Service  |  Environment Config
# ─────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/wandr_db

# SQLite (for quick local dev — swap above line)
# DATABASE_URL=sqlite:///./wandr.db

# JWT
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
APP_NAME=Wandr
